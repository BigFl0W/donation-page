#############################################
# Friends At Heart Welfare Initiative
# Production environment template
#
# Notes:
# - Keep one KEY=value per line
# - Do not add inline comments after values
# - Use quotes only when a value contains spaces
# - Replace every example secret before going live
#############################################

############################
# APP SETTINGS
############################
APP_NAME="Friends At Heart Welfare Initiative"
APP_URL="https://yourdomain.com"
ADMIN_PATH="admin"
APP_TIMEZONE="Africa/Lagos"
SESSION_NAME="fahwi_admin_session"

############################
# DATABASE
############################
DB_DRIVER="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="your_database_name"
DB_USERNAME="your_database_user"
DB_PASSWORD="your_database_password"
DB_CHARSET="utf8mb4"

############################
# PAYSTACK
############################
PAYSTACK_PUBLIC_KEY="pk_live_replace_me"
PAYSTACK_SECRET_KEY="sk_live_replace_me"

############################
# SMTP / MAIL
############################
SMTP_ENABLED=true
SMTP_HOST="smtp.yourmailhost.com"
SMTP_PORT="587"
SMTP_USER="noreply@yourdomain.com"
SMTP_PASS="replace_with_real_smtp_password"
SMTP_SECURE="tls"
SMTP_FROM_EMAIL="noreply@yourdomain.com"
SMTP_FROM_NAME="Friends At Heart Welfare Initiative"
