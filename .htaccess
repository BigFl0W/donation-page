RewriteEngine On
DirectoryIndex index.php

# ------------------------------------------------------------------
# Error document – any 404 status (Apache internal or PHP‑set) will
# show the custom 404 page (path relative to DocumentRoot).
# ------------------------------------------------------------------
ErrorDocument 404 /404-page.php

# ------------------------------------------------------------------
# Redirect explicit .php requests to clean public URLs.
# ------------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+about-us\.php[\s?] [NC]
RewriteRule ^about-us\.php$ /about-us [R=301,L]

RewriteCond %{THE_REQUEST} \s/+blog\.php[\s?] [NC]
RewriteRule ^blog\.php$ /blog [R=301,L]

RewriteCond %{THE_REQUEST} \s/+events\.php[\s?] [NC]
RewriteRule ^events\.php$ /events [R=301,L]

RewriteCond %{THE_REQUEST} \s/+gallery\.php[\s?] [NC]
RewriteRule ^gallery\.php$ /gallery [R=301,L]

RewriteCond %{THE_REQUEST} \s/+faqs\.php[\s?] [NC]
RewriteRule ^faqs\.php$ /faqs [R=301,L]

RewriteCond %{THE_REQUEST} \s/+contact-us\.php[\s?] [NC]
RewriteRule ^contact-us\.php$ /contact-us [R=301,L]

RewriteCond %{THE_REQUEST} \s/+donation-page\.php[\s?] [NC]
RewriteRule ^donation-page\.php$ /donation-page [R=301,L]

RewriteCond %{THE_REQUEST} \s/+programme\.php[\s?] [NC]
RewriteRule ^programme\.php$ /programme [R=301,L]

RewriteCond %{THE_REQUEST} \s/+causes\.php[\s?] [NC]
RewriteRule ^causes\.php$ /causes-projects [R=301,L]

RewriteCond %{THE_REQUEST} \s/+partners-sponsors\.php[\s?] [NC]
RewriteRule ^partners-sponsors\.php$ /partners-sponsors [R=301,L]

RewriteCond %{THE_REQUEST} \s/+volunteer\.php[\s?] [NC]
RewriteRule ^volunteer\.php$ /volunteer [R=301,L]

RewriteCond %{THE_REQUEST} \s/+success\.php[\s?] [NC]
RewriteRule ^success\.php$ /success [R=301,L]

# ------------------------------------------------------------------
# Existing files & directories – serve them directly.
# ------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ------------------------------------------------------------------
# Extensionless public page URLs
# ------------------------------------------------------------------

# Blog
RewriteRule ^blog/?$                                            blog.php [L,QSA]
RewriteRule ^blog/([a-zA-Z0-9-]+)/([a-zA-Z0-9-]+)/?$           post.php?category=$1&slug=$2 [L,QSA]

# Events
RewriteRule ^events/?$                                           events.php [L,QSA]
RewriteRule ^event/([a-zA-Z0-9-]+)/?$                            event.php?slug=$1 [L,QSA]

# Gallery & FAQs
RewriteRule ^gallery/?$                                          gallery.php [L,QSA]
RewriteRule ^faqs/?$                                             faqs.php [L,QSA]
RewriteRule ^success/?$                                          success.php [L,QSA]

# Contact & About
RewriteRule ^contact-us/?$                                       contact-us.php [L,QSA]
RewriteRule ^about-us/?$                                         about-us.php [L,QSA]
RewriteRule ^programme/?$                                        programme.php [L,QSA]

# Donation
RewriteRule ^donation-page/?$                                    donation-page.php [L,QSA]

# Volunteers
RewriteRule ^volunteer/?$                                        volunteer.php [L,QSA]
RewriteRule ^volunteers/?$                                       volunteers.php [L,QSA]
RewriteRule ^volunteer/([a-zA-Z0-9-]+)/?$                        volunteers-single.php?slug=$1 [L,QSA]
RewriteRule ^become-volunteers/?$                                become-volunteers.php [L,QSA]

# Programmes & Partners
RewriteRule ^causes-projects/?$                                  causes.php [L,QSA]
RewriteRule ^cause/([a-zA-Z0-9-]+)/?$                            causes-single.php?slug=$1 [L,QSA]
RewriteRule ^partners-sponsors/?$                                 partners-sponsors.php [L,QSA]

# Admin
RewriteRule ^admin/?$                                            admin/index.php [L,QSA]

# ------------------------------------------------------------------
# Catch‑all – anything that wasn't matched above goes to the 404
# page instead of exposing a PHP error or Apache's default 404.
# ------------------------------------------------------------------
RewriteRule . 404-page.php [L]
